generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                                      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  fullName                                                                String                    @map("full_name") @db.VarChar(150)
  email                                                                   String                    @unique(map: "email") @db.VarChar(150)
  phone                                                                   String?                   @unique(map: "phone") @db.VarChar(20)
  identityNumber                                                          String?                   @unique(map: "identity_number") @map("identity_number") @db.VarChar(30)
  birthDate                                                               DateTime?                 @map("birth_date") @db.Date
  dietaryNotes                                                            String?                   @map("dietary_notes") @db.Text
  healthNotes                                                             String?                   @map("health_notes") @db.Text
  passwordHash                                                            String?                   @map("password_hash") @db.VarChar(255)
  googleId                                                                String?                   @unique(map: "google_id") @map("google_id") @db.VarChar(255)
  authProvider                                                            String                    @default("local") @map("auth_provider") @db.VarChar(30)
  avatarUrl                                                               String?                   @map("avatar_url") @db.VarChar(500)
  role                                                                    Role                      @default(user)
  status                                                                  UserStatus                @default(active)
  memberPoints                                                            Int                       @default(0) @map("member_points") @db.UnsignedInt
  memberTier                                                              MemberTier                @default(bronze) @map("member_tier")
  createdAt                                                               DateTime                  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt                                                               DateTime                  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  passwordChangedAt                                                       DateTime?                 @map("password_changed_at") @db.DateTime(0)
  failedLoginAttempts                                                     Int                       @default(0) @map("failed_login_attempts")
  lockedUntil                                                             DateTime?                 @map("locked_until") @db.DateTime(0)
  lastLoginAt                                                             DateTime?                 @map("last_login_at") @db.DateTime(0)
  lastLoginIp                                                             String?                   @map("last_login_ip") @db.VarChar(50)
  booking_status_logs                                                     BookingStatusLog[]
  bookings                                                                Booking[]
  chatConversations                                                       ChatConversation[]
  contactEmailLogs                                                        ContactEmailLog[]         @relation("ContactEmailLogAdmin")
  contacts                                                                Contact[]                 @relation("ContactOwner")
  handledContacts                                                         Contact[]                 @relation("ContactHandler")
  departure_change_requests_departure_change_requests_requested_byTousers DepartureChangeRequest[]  @relation("departure_change_requests_requested_byTousers")
  departure_change_requests_departure_change_requests_reviewed_byTousers  DepartureChangeRequest[]  @relation("departure_change_requests_reviewed_byTousers")
  favoriteTours                                                           FavoriteTour[]
  approvedGuideAvailabilities                                             GuideAvailability[]       @relation("GuideAvailabilityApprover")
  createdGuideAvailabilities                                              GuideAvailability[]       @relation("GuideAvailabilityCreator")
  verifiedGuideCompetencies                                               GuideCompetency[]         @relation("GuideCompetencyVerifier")
  assignedGuide                                                           Guide?                    @relation("GuideUserAccount")
  incidentComments                                                        IncidentTicketComment[]
  assignedIncidentTickets                                                 IncidentTicket[]          @relation("IncidentAssignedAdmin")
  itinerary_change_requests_itinerary_change_requests_requested_byTousers ItineraryChangeRequest[]  @relation("itinerary_change_requests_requested_byTousers")
  itinerary_change_requests_itinerary_change_requests_reviewed_byTousers  ItineraryChangeRequest[]  @relation("itinerary_change_requests_reviewed_byTousers")
  notificationReads                                                       NotificationRead[]
  targetedNotifications                                                   Notification[]            @relation("NotificationTargetUser")
  createdNotifications                                                    Notification[]            @relation("NotificationCreator")
  passengerCheckins                                                       PassengerCheckin[]        @relation("PassengerCheckinUser")
  password_histories_password_histories_changed_byTousers                 PasswordHistory[]         @relation("password_histories_changed_byTousers")
  password_histories_password_histories_user_idTousers                    PasswordHistory[]         @relation("password_histories_user_idTousers")
  recommendationFactor                                                    RecommendationUserFactor?
  refundRequests                                                          RefundRequest[]
  refund_requests_refund_requests_reviewed_byTousers                      RefundRequest[]           @relation("refund_requests_reviewed_byTousers")
  reviews                                                                 Review[]
  revoked_tokens                                                          RevokedToken[]
  savedTravelers                                                          SavedTraveler[]
  ticket_scan_logs                                                        TicketScanLog[]
  tripBroadcastRecipients                                                 TripBroadcastRecipient[]
  sentTripBroadcasts                                                      TripBroadcast[]           @relation("TripBroadcastSenderUser")
  trip_checklist_items                                                    TripChecklistItem[]
  trip_documents                                                          TripDocument[]
  trip_itinerary_items                                                    TripItineraryItem[]
  createdTripOperations                                                   TripOperation[]           @relation("TripOperationCreator")
  reviewedTripReports                                                     TripReport[]              @relation("TripReportReviewer")
  behaviors                                                               UserBehavior[]
  user_sessions                                                           UserSession[]
  userVouchers                                                            UserVoucher[]

  @@map("users")
}

model Destination {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name        String   @db.VarChar(150)
  province    String   @db.VarChar(100)
  country     String   @default("Vietnam") @db.VarChar(100)
  description String?  @db.Text
  coverImage  String?  @map("cover_image") @db.VarChar(500)
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  tours       Tour[]

  @@map("destinations")
}

model Tour {
  id                   BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  code                 String                    @unique(map: "code") @db.VarChar(50)
  name                 String                    @db.VarChar(220)
  slug                 String                    @unique(map: "slug") @db.VarChar(240)
  destinationId        BigInt                    @map("destination_id") @db.UnsignedBigInt
  tourType             TourType                  @default(group) @map("tour_type")
  tourTheme            TourTheme                 @default(other) @map("tour_theme")
  durationDays         Int                       @map("duration_days") @db.UnsignedSmallInt
  durationNights       Int                       @map("duration_nights") @db.UnsignedSmallInt
  hotelStars           Int?                      @map("hotel_stars") @db.UnsignedTinyInt
  basePriceAdult       Decimal                   @map("base_price_adult") @db.Decimal(12, 2)
  basePriceChild       Decimal                   @map("base_price_child") @db.Decimal(12, 2)
  maxCapacityDefault   Int                       @default(30) @map("max_capacity_default") @db.UnsignedInt
  shortDescription     String?                   @map("short_description") @db.VarChar(500)
  fullDescription      String?                   @map("full_description") @db.LongText
  status               TourStatus                @default(published)
  isTrending           Boolean                   @default(false) @map("is_trending")
  isBestDeal           Boolean                   @default(false) @map("is_best_deal")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt            DateTime                  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  bookings             Booking[]
  favorites            FavoriteTour[]
  guideAssignments     GuideAssignment[]
  recommendationFactor RecommendationTourFactor?
  reviews              Review[]
  accommodations       TourAccommodation[]
  departures           TourDeparture[]
  embedding            TourEmbedding?
  itinerary            TourItinerary[]
  media                TourMedia[]
  pickupPoints         TourPickupPoint[]
  policies             TourPolicy[]
  transports           TourTransport[]
  destination          Destination               @relation(fields: [destinationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tours_destination")
  behaviors            UserBehavior[]

  @@index([destinationId], map: "fk_tours_destination")
  @@map("tours")
}

model TourMedia {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tourId       BigInt    @map("tour_id") @db.UnsignedBigInt
  mediaType    MediaType @default(image) @map("media_type")
  fileUrl      String    @map("file_url") @db.VarChar(500)
  isCover      Boolean   @default(false) @map("is_cover")
  displayOrder Int       @default(1) @map("display_order") @db.UnsignedInt
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  tour         Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_media_ibfk_1")

  @@index([tourId], map: "tour_id")
  @@map("tour_media")
}

model TourItinerary {
  id                   BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  tourId               BigInt              @map("tour_id") @db.UnsignedBigInt
  dayNumber            Int                 @map("day_number") @db.UnsignedSmallInt
  itemOrder            Int                 @default(1) @map("item_order") @db.UnsignedSmallInt
  title                String              @db.VarChar(220)
  description          String?             @db.Text
  locationName         String?             @map("location_name") @db.VarChar(200)
  createdAt            DateTime            @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt            DateTime            @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  tour                 Tour                @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_itinerary_ibfk_1")
  trip_itinerary_items TripItineraryItem[]

  @@unique([tourId, dayNumber, itemOrder], map: "uk_tour_day_order")
  @@map("tour_itinerary")
}

model TourDeparture {
  id                                                                                    BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  tourId                                                                                BigInt                   @map("tour_id") @db.UnsignedBigInt
  departureDate                                                                         DateTime                 @map("departure_date") @db.Date
  endDate                                                                               DateTime                 @map("end_date") @db.Date
  adultPrice                                                                            Decimal                  @map("adult_price") @db.Decimal(12, 2)
  childPrice                                                                            Decimal                  @map("child_price") @db.Decimal(12, 2)
  totalSlots                                                                            Int                      @map("total_slots") @db.UnsignedInt
  bookedSlots                                                                           Int                      @default(0) @map("booked_slots") @db.UnsignedInt
  heldSlots                                                                             Int                      @default(0) @map("held_slots") @db.UnsignedInt
  status                                                                                DepartureStatus          @default(open)
  createdAt                                                                             DateTime                 @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt                                                                             DateTime                 @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  bookings                                                                              Booking[]
  departure_change_requests_departure_change_requests_new_departure_idTotour_departures DepartureChangeRequest[] @relation("departure_change_requests_new_departure_idTotour_departures")
  departure_change_requests_departure_change_requests_old_departure_idTotour_departures DepartureChangeRequest[] @relation("departure_change_requests_old_departure_idTotour_departures")
  electronic_tickets                                                                    ElectronicTicket[]
  tour                                                                                  Tour                     @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_departures_ibfk_1")
  pickupPoints                                                                          TourPickupPoint[]
  tripOperation                                                                         TripOperation?

  @@index([tourId], map: "tour_id")
  @@map("tour_departures")
}

model TourPickupPoint {
  id             BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  tourId         BigInt          @map("tour_id") @db.UnsignedBigInt
  departureId    BigInt?         @map("departure_id") @db.UnsignedBigInt
  province       String          @db.VarChar(100)
  name           String          @db.VarChar(180)
  address        String          @db.VarChar(255)
  pickupTime     DateTime?       @map("pickup_time") @db.Time(0)
  note           String?         @db.Text
  status         String          @default("active") @db.VarChar(30)
  createdAt      DateTime?       @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime?       @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  bookings       Booking[]
  tour           Tour            @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_pickup_points_ibfk_1")
  departure      TourDeparture?  @relation(fields: [departureId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_pickup_points_ibfk_2")
  tripBroadcasts TripBroadcast[]

  @@index([departureId], map: "departure_id")
  @@index([tourId], map: "tour_id")
  @@map("tour_pickup_points")
}

model TourPolicy {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tourId       BigInt   @map("tour_id") @db.UnsignedBigInt
  policyType   String   @map("policy_type") @db.VarChar(50)
  content      String   @db.Text
  displayOrder Int      @default(1) @map("display_order") @db.UnsignedSmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  tour         Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_policies_ibfk_1")

  @@index([tourId], map: "tour_id")
  @@map("tour_policies")
}

model TourAccommodation {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tourId            BigInt    @map("tour_id") @db.UnsignedBigInt
  supplierId        BigInt?   @map("supplier_id") @db.UnsignedBigInt
  name              String    @db.VarChar(180)
  accommodationType String    @map("accommodation_type") @db.VarChar(50)
  starRating        Int?      @map("star_rating") @db.UnsignedTinyInt
  address           String?   @db.VarChar(255)
  description       String?   @db.Text
  pricePerNight     Decimal?  @map("price_per_night") @db.Decimal(12, 2)
  imageUrl          String?   @map("image_url") @db.VarChar(500)
  amenities         String?   @db.Text
  status            String    @default("active") @db.VarChar(30)
  createdAt         DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  supplier          Supplier? @relation("SupplierAccommodations", fields: [supplierId], references: [id], map: "fk_tour_accommodations_supplier")
  tour              Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_accommodations_ibfk_1")

  @@index([supplierId], map: "idx_tour_accommodations_supplier")
  @@index([tourId], map: "tour_id")
  @@map("tour_accommodations")
}

model TourTransport {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tourId           BigInt    @map("tour_id") @db.UnsignedBigInt
  supplierId       BigInt?   @map("supplier_id") @db.UnsignedBigInt
  name             String    @default("Phương tiện tour") @db.VarChar(180)
  transportType    String    @map("transport_type") @db.VarChar(50)
  provider         String?   @db.VarChar(150)
  origin           String?   @db.VarChar(150)
  destinationLabel String?   @map("destination_label") @db.VarChar(150)
  durationHours    Decimal?  @map("duration_hours") @db.Decimal(8, 2)
  price            Decimal?  @db.Decimal(12, 2)
  description      String?   @db.Text
  imageUrl         String?   @map("image_url") @db.VarChar(500)
  status           String    @default("active") @db.VarChar(30)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  supplier         Supplier? @relation("SupplierTransports", fields: [supplierId], references: [id], map: "fk_tour_transports_supplier")
  tour             Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tour_transports_ibfk_1")

  @@index([supplierId], map: "idx_tour_transports_supplier")
  @@index([tourId], map: "tour_id")
  @@map("tour_transports")
}

model Booking {
  id                        BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  bookingCode               String                   @unique(map: "booking_code") @map("booking_code") @db.VarChar(50)
  userId                    BigInt?                  @map("user_id") @db.UnsignedBigInt
  tourId                    BigInt                   @map("tour_id") @db.UnsignedBigInt
  departureId               BigInt                   @map("departure_id") @db.UnsignedBigInt
  voucherId                 BigInt?                  @map("voucher_id") @db.UnsignedBigInt
  voucherCode               String?                  @map("voucher_code") @db.VarChar(50)
  pickupPointId             BigInt?                  @map("pickup_point_id") @db.UnsignedBigInt
  pickupName                String?                  @map("pickup_name") @db.VarChar(180)
  pickupAddress             String?                  @map("pickup_address") @db.VarChar(255)
  pickupTime                DateTime?                @map("pickup_time") @db.Time(0)
  pickupNote                String?                  @map("pickup_note") @db.Text
  adultCount                Int                      @default(1) @map("adult_count")
  childCount                Int                      @default(0) @map("child_count")
  originalAmount            Decimal                  @map("original_amount") @db.Decimal(12, 2)
  discountAmount            Decimal                  @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  finalAmount               Decimal                  @map("final_amount") @db.Decimal(12, 2)
  bookingStatus             BookingStatus            @default(pending_payment) @map("booking_status")
  holdExpiresAt             DateTime?                @map("hold_expires_at") @db.DateTime(0)
  contactName               String                   @map("contact_name") @db.VarChar(150)
  contactEmail              String                   @map("contact_email") @db.VarChar(150)
  contactPhone              String                   @map("contact_phone") @db.VarChar(20)
  note                      String?                  @db.Text
  createdAt                 DateTime                 @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt                 DateTime                 @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  guests                    BookingGuest[]
  logs                      BookingStatusLog[]
  user                      User?                    @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "bookings_ibfk_1")
  tour                      Tour                     @relation(fields: [tourId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "bookings_ibfk_2")
  departure                 TourDeparture            @relation(fields: [departureId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "bookings_ibfk_3")
  voucher                   Voucher?                 @relation(fields: [voucherId], references: [id], onUpdate: NoAction, map: "bookings_ibfk_4")
  pickupPoint               TourPickupPoint?         @relation(fields: [pickupPointId], references: [id], onUpdate: NoAction, map: "bookings_ibfk_5")
  departure_change_requests DepartureChangeRequest[]
  electronic_tickets        ElectronicTicket[]
  guideAssignments          GuideAssignment[]
  incidentTickets           IncidentTicket[]
  payments                  Payment[]
  refundRequests            RefundRequest[]
  reviews                   Review[]
  broadcastRecipients       TripBroadcastRecipient[]

  @@index([departureId], map: "idx_booking_departure")
  @@index([bookingStatus], map: "idx_booking_status")
  @@index([userId], map: "idx_booking_user")
  @@index([pickupPointId], map: "pickup_point_id")
  @@index([tourId], map: "tour_id")
  @@index([voucherId], map: "voucher_id")
  @@map("bookings")
}

model BookingGuest {
  id                    BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  bookingId             BigInt             @map("booking_id") @db.UnsignedBigInt
  fullName              String             @map("full_name") @db.VarChar(150)
  dateOfBirth           DateTime?          @map("date_of_birth") @db.Date
  gender                String?            @db.VarChar(20)
  guestType             String             @map("guest_type") @db.VarChar(20)
  idNumber              String?            @map("id_number") @db.VarChar(50)
  createdAt             DateTime           @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt             DateTime           @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  savedTravelerId       BigInt?            @map("saved_traveler_id") @db.UnsignedBigInt
  nationality           String?            @db.VarChar(80)
  phone                 String?            @db.VarChar(20)
  dietaryNotes          String?            @map("dietary_notes") @db.VarChar(500)
  healthNotes           String?            @map("health_notes") @db.VarChar(500)
  allergyNotes          String?            @map("allergy_notes") @db.VarChar(500)
  emergencyContactName  String?            @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactPhone String?            @map("emergency_contact_phone") @db.VarChar(20)
  booking               Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "booking_guests_ibfk_1")
  electronic_tickets    ElectronicTicket[]
  incidentTickets       IncidentTicket[]
  passengerCheckins     PassengerCheckin[]

  @@index([bookingId], map: "booking_id")
  @@map("booking_guests")
}

model Payment {
  id                      BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  bookingId               BigInt             @map("booking_id") @db.UnsignedBigInt
  paymentMethod           PaymentMethod      @map("payment_method")
  paymentStatus           PaymentStatus      @default(pending) @map("payment_status")
  amount                  Decimal            @db.Decimal(12, 2)
  internalTransactionCode String             @unique(map: "internal_transaction_code") @map("internal_transaction_code") @db.VarChar(80)
  gatewayTransactionId    String?            @map("gateway_transaction_id") @db.VarChar(120)
  paidAt                  DateTime?          @map("paid_at") @db.DateTime(0)
  createdAt               DateTime           @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt               DateTime           @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  logs                    BookingStatusLog[]
  booking                 Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "payments_ibfk_1")

  @@index([bookingId], map: "booking_id")
  @@map("payments")
}

model BookingStatusLog {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  bookingId       BigInt    @map("booking_id") @db.UnsignedBigInt
  paymentId       BigInt?   @map("payment_id") @db.UnsignedBigInt
  actionType      String    @map("action_type") @db.VarChar(50)
  oldStatus       String?   @map("old_status") @db.VarChar(50)
  newStatus       String?   @map("new_status") @db.VarChar(50)
  changedByUserId BigInt?   @map("changed_by_user_id") @db.UnsignedBigInt
  source          String    @default("system") @db.VarChar(50)
  reason          String?   @db.Text
  note            String?   @db.Text
  createdAt       DateTime? @default(now()) @map("created_at") @db.DateTime(0)
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "booking_status_logs_ibfk_1")
  payment         Payment?  @relation(fields: [paymentId], references: [id], onUpdate: NoAction, map: "booking_status_logs_ibfk_2")
  users           User?     @relation(fields: [changedByUserId], references: [id], onUpdate: NoAction, map: "booking_status_logs_ibfk_3")

  @@index([bookingId], map: "booking_id")
  @@index([changedByUserId], map: "changed_by_user_id")
  @@index([paymentId], map: "payment_id")
  @@map("booking_status_logs")
}

model Review {
  id           BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt?       @map("user_id") @db.UnsignedBigInt
  tourId       BigInt        @map("tour_id") @db.UnsignedBigInt
  bookingId    BigInt?       @map("booking_id") @db.UnsignedBigInt
  rating       Int           @db.UnsignedTinyInt
  comment      String?       @db.Text
  adminReply   String?       @map("admin_reply") @db.Text
  adminReplyAt DateTime?     @map("admin_reply_at") @db.DateTime(0)
  status       ReviewStatus  @default(approved)
  createdAt    DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  media        ReviewMedia[]
  user         User?         @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "reviews_ibfk_1")
  tour         Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_ibfk_2")
  booking      Booking?      @relation(fields: [bookingId], references: [id], onUpdate: NoAction, map: "reviews_ibfk_3")

  @@index([bookingId], map: "booking_id")
  @@index([tourId], map: "tour_id")
  @@index([userId], map: "user_id")
  @@map("reviews")
}

